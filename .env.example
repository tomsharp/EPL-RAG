# Copy this file to .env and fill in your values

# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# --- Weaviate (overridden in docker-compose for container networking) ---
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051
WEAVIATE_SECURE=false
COLLECTION_NAME=EplNews

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Ingestion schedule ---
INGEST_INTERVAL_MINUTES=30

# --- RAG settings ---
MAX_HISTORY_TURNS=5
MAX_CONTEXT_DOCS=5

# --- Live stats (football-data.org — free tier, leave blank to disable) ---
# Get a free key at: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=
STATS_CACHE_TTL_SECONDS=600

# --- Auth (leave blank to disable password protection) ---
APP_PASSWORD=

# --- Feedback email — Resend (leave blank to disable) ---
RESEND_API_KEY=
FEEDBACK_EMAIL_TO=you@yourdomain.com

# --- Observability (Arize Phoenix Cloud — leave blank to disable) ---
# Get a free API key at: https://app.phoenix.arize.com
PHOENIX_API_KEY=
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/<your-org-slug>
PHOENIX_PROJECT=default
